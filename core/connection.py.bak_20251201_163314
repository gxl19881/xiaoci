    async def _try_replay_recent_vision_result(self, window_seconds: int = 60):
        """鍦ㄦ柊杩炴帴寤虹珛鍚庯紝鐭獥鍥炴斁鏈€杩戠殑瑙嗚缁撴灉锛岄伩鍏嶆媿鐓х粨鏉熶絾涓婃杩炴帴宸叉柇寮€鏃朵涪鎾€?
        绛栫暐锛?        - 鍦?data/vision_records/YYYYMMDD 涓嬶紝鏌ユ壘鍖呭惈褰撳墠 client-id 鍓?浣嶇殑鏈€杩?.json锛?        - 浠呭洖鏀句慨鏀规椂闂村湪 window_seconds 鍐呯殑缁撴灉锛?        - 鏂囨湰鍏堣繘琛?sanitize锛屽啀鐩存帴TTS鎾姤锛屽苟鍔犲叆褰撳墠浼氳瘽瀵硅瘽璁板綍銆?        """
        try:
            cid = (self.headers.get("client-id", "") or "")[:8]
            if not cid:
                return
            from datetime import datetime, timedelta
            base = os.path.abspath(os.path.join(os.getcwd(), "data", "vision_records"))
            day_dir = os.path.join(base, datetime.now().strftime("%Y%m%d"))
            if not os.path.isdir(day_dir):
                return
            now = datetime.now()
            candidates = [
                f for f in os.listdir(day_dir) if f.endswith(".json") and cid in f
            ]
            if not candidates:
                return
            # 鍙栨渶杩戠殑鍑犱釜鏂囦欢妫€鏌ユ椂闂寸獥
            candidates.sort(
                key=lambda fn: os.path.getmtime(os.path.join(day_dir, fn)),
                reverse=True,
            )
            for fn in candidates[:5]:
                p = os.path.join(day_dir, fn)
                mtime = datetime.fromtimestamp(os.path.getmtime(p))
                if (now - mtime).total_seconds() > window_seconds:
                    continue
                try:
                    import json as _json
                    with open(p, "r", encoding="utf-8") as jf:
                        data = _json.load(jf)
                    if isinstance(data, dict) and data.get("success") is True and data.get("action") == "RESPONSE":
                        text = data.get("response") or ""
                        if not text:
                            continue
                        try:
                            from core.utils import textUtils as _txu
                            text = _txu.sanitize_for_device(text)
                        except Exception:
                            pass
                        # 鐩存帴杩涜鍒嗘鎾姤锛屾槑纭?FIRST/MIDDLE/LAST锛岄伩鍏嶈澶囩鍙ョ晫涓嶅畬鏁?                        self._speak_vision_response(text)
                        # 鍚屾鍐欏叆瀵硅瘽
                        self.dialogue.put(Message(role="assistant", content=text))
                        try:
                            self._append_conversation_event(question=self._get_last_user_content(), reply=text, source="realtime")
                        except Exception:
                            pass
                        self.logger.bind(tag=TAG).info("閲嶈繛鍚庡洖鏀炬渶杩戣瑙夌粨鏋滃畬鎴?)
                        # 鍒锋柊娲诲姩鏃堕棿锛岄槻姝㈢揣鎺ョ潃琚秴鏃舵竻鐞?                        self.last_activity_time = time.time() * 1000
                        return
                except Exception:
                    continue
        except Exception as _e:
            try:
                self.logger.bind(tag=TAG).warning(f"閲嶈繛瑙嗚缁撴灉鍥炴斁澶辫触: {_e}")
            except Exception:
                pass

    def _append_conversation_event(self, question: str, reply: str, files=None, source: str = "realtime"):
        """灏嗕竴杞璇濆啓鍏?data/conversations/YYYYMMDD/<session_id>.jsonl
        - conversation_id 閲囩敤褰撳墠杩炴帴鐨?session_id锛堝悓涓€杩炴帴鍐呭綊妗ｅ埌鍚屼竴鏂囦欢锛?        - 瀛﹀彿鏉ヨ嚜鎻℃墜澶翠繚瀛樼殑 self.student_id锛堝鏋滄病鏈夊垯涓虹┖瀛楃涓诧級
        """
        try:
            from datetime import datetime as _dt
            import json as _json
            # 瀛樻。鍓嶅噣鍖栨枃鏈紝鍘婚櫎 Markdown/LaTeX/鐗规畩绗﹀彿锛屼繚璇佹煡鐪嬩笌璁惧涓€鑷?            try:
                from core.utils import textUtils as _txu
                _q = _txu.sanitize_for_device(question or "")
                _r = _txu.sanitize_for_device(reply or "")
            except Exception:
                _q = question or ""
                _r = reply or ""
            now = _dt.now()
            date_str = now.strftime("%Y%m%d")
            out_dir = os.path.join(self._data_root, "conversations", date_str)
            os.makedirs(out_dir, exist_ok=True)
            cid = (self.session_id or _dt.now().strftime("%H%M%S"))
            line = {
                "timestamp": now.isoformat(timespec="seconds"),
                "source": source or "realtime",
                "student_id": (self.student_id or ""),
                "question": _q,
                "reply": _r,
                "files": [f for f in (files or []) if f],
            }
            with open(os.path.join(out_dir, f"{cid}.jsonl"), "a", encoding="utf-8") as f:
                f.write(_json.dumps(line, ensure_ascii=False) + "\n")
        except Exception as _e:
            try:
                self.logger.bind(tag=TAG).warning(f"淇濆瓨瀵硅瘽璁板綍澶辫触: {_e}")
            except Exception:
                pass

    def _get_last_user_content(self) -> str:
        try:
            for m in reversed(self.dialogue.dialogue):
                if getattr(m, "role", None) == "user" and getattr(m, "content", None):
                    return m.content
        except Exception:
            pass
        return ""

    async def handle_connection(self, ws):
        try:
            # 鑾峰彇骞堕獙璇乭eaders
            self.headers = dict(ws.request.headers)

            if self.headers.get("device-id", None) is None:
                # 灏濊瘯浠?URL 鐨勬煡璇㈠弬鏁颁腑鑾峰彇 device-id
                from urllib.parse import parse_qs, urlparse

                # 浠?WebSocket 璇锋眰涓幏鍙栬矾寰?                request_path = ws.request.path
                if not request_path:
                    self.logger.bind(tag=TAG).error("鏃犳硶鑾峰彇璇锋眰璺緞")
                    return
                parsed_url = urlparse(request_path)
                query_params = parse_qs(parsed_url.query)
                if "device-id" in query_params:
                    self.headers["device-id"] = query_params["device-id"][0]
                    self.headers["client-id"] = query_params["client-id"][0]
                else:
                    await ws.send("绔彛姝ｅ父锛屽闇€娴嬭瘯杩炴帴锛岃浣跨敤test_page.html")
                    await self.close(ws)
                    return
            real_ip = self.headers.get("x-real-ip") or self.headers.get(
                "x-forwarded-for"
            )
            if real_ip:
                self.client_ip = real_ip.split(",")[0].strip()
            else:
                self.client_ip = ws.remote_address[0]
            self.logger.bind(tag=TAG).info(
                f"{self.client_ip} conn - Headers: {self.headers}"
            )

            # 鎻愬彇骞惰褰曞鍙凤紙鑻ュ鎴风鍦ㄦ彙鎵嬪ご涓紶閫掍簡 Student-Id锛?            try:
                sid_header = (
                    self.headers.get("Student-Id")
                    or self.headers.get("student-id")
                    or self.headers.get("student_id")
                )
                if sid_header:
                    self.student_id = str(sid_header).strip()
                    self.logger.bind(tag=TAG).info(
                        f"鎻愬彇鍒板鍙?鏉ヨ嚜Header): {self.student_id}"
                    )
                else:
                    self.logger.bind(tag=TAG).info("鏈湪Header涓彂鐜板鍙?Student-Id)")
            except Exception as _e:
                self.logger.bind(tag=TAG).warning(
                    f"瑙ｆ瀽Header涓璖tudent-Id寮傚父: {_e}"
                )

            # 灏濊瘯浠?Header 鎴?URL 鏌ヨ鍙傛暟涓彁鍙栭煶棰戞牸寮忥紝浼樺厛绾э細Header > Query
            try:
                audio_fmt_header = (
                    self.headers.get("Audio-Format")
                    or self.headers.get("audio-format")
                    or self.headers.get("audio_format")
                )
                fmt_from_header = (
                    str(audio_fmt_header).strip().lower() if audio_fmt_header else None
                )

                # 瑙ｆ瀽鏌ヨ鍙傛暟锛堝缁堣В鏋愶紝浠ヤ究鑾峰彇 audio_format锛?                from urllib.parse import parse_qs, urlparse

                parsed_url_all = urlparse(ws.request.path or "")
                query_params_all = parse_qs(parsed_url_all.query)
                fmt_from_query = None
                if "audio_format" in query_params_all:
                    fmt_from_query = (
                        query_params_all.get("audio_format", [None])[0] or ""
                    ).strip().lower()

                final_fmt = fmt_from_header or fmt_from_query
                if final_fmt in ("pcm", "opus"):
                    self.audio_format = final_fmt
                    self.logger.bind(tag=TAG).info(
                        f"闊抽鏍煎紡璁惧畾: {self.audio_format} (鏉ユ簮: {'Header' if fmt_from_header else 'Query'})"
                    )
                elif final_fmt:
                    self.logger.bind(tag=TAG).warning(
                        f"鏀跺埌鏈煡闊抽鏍煎紡: {final_fmt}锛屼繚鎸侀粯璁? {self.audio_format}"
                    )
            except Exception as _e:
                self.logger.bind(tag=TAG).warning(f"瑙ｆ瀽闊抽鏍煎紡澶辫触: {_e}")

            # 瑙ｆ瀽PCM绔簭锛屽彲閫夊ご锛歅CM-Endian/pcm-endian/pcm_endian锛屽€间负 le 鎴?be
            try:
                endian_header = (
                    self.headers.get("PCM-Endian")
                    or self.headers.get("pcm-endian")
                    or self.headers.get("pcm_endian")
                )
                if endian_header:
                    endian = str(endian_header).strip().lower()
                    if endian in ("le", "be"):
                        self.pcm_endian = endian
                        self.logger.bind(tag=TAG).info(
                            f"PCM绔簭璁惧畾: {self.pcm_endian} (鏉ユ簮: Header)"
                        )
                    else:
                        self.logger.bind(tag=TAG).warning(
                            f"鏀跺埌鏈煡PCM绔簭: {endian}锛屼繚鎸侀粯璁? {self.pcm_endian}"
                        )
            except Exception as _e:
                self.logger.bind(tag=TAG).warning(f"瑙ｆ瀽PCM绔簭澶辫触: {_e}")

            # 瑙ｆ瀽PCM缂栫爜锛屽彲閫夊ご锛歅CM-Encoding/pcm-encoding/pcm_encoding锛屽€间负 s16 鎴?u16
            try:
                enc_header = (
                    self.headers.get("PCM-Encoding")
                    or self.headers.get("pcm-encoding")
                    or self.headers.get("pcm_encoding")
                )
                if enc_header:
                    enc = str(enc_header).strip().lower()
                    if enc in ("s16", "u16"):
                        self.pcm_encoding = enc
                        self.logger.bind(tag=TAG).info(
                            f"PCM缂栫爜璁惧畾: {self.pcm_encoding} (鏉ユ簮: Header)"
                        )
                    else:
                        self.logger.bind(tag=TAG).warning(
                            f"鏀跺埌鏈煡PCM缂栫爜: {enc}锛屼繚鎸侀粯璁? {self.pcm_encoding}"
                        )
            except Exception as _e:
                self.logger.bind(tag=TAG).warning(f"瑙ｆ瀽PCM缂栫爜澶辫触: {_e}")

            # 瑙ｆ瀽ASR璇█瑕嗙洊锛屽彲閫夊ご锛欰SR-Language/asr-language/asr_language锛堜緥濡?zh/en/yue锛?            try:
                asr_lang_header = (
                    self.headers.get("ASR-Language")
                    or self.headers.get("asr-language")
                    or self.headers.get("asr_language")
                )
                if asr_lang_header:
                    lang = str(asr_lang_header).strip().lower()
                    # 绠€鍗曟牎楠岋紙鍏佽瀛楁瘝鍜岃繛瀛楃锛?                    if all(c.isalpha() or c in ("-", "_") for c in lang):
                        self.asr_language = lang
