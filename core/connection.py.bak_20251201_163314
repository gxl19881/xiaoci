        elif isinstance(message, bytes):
            if self.vad is None or self.asr is None:
                return

            # 澶勭悊鏉ヨ嚜MQTT缃戝叧鐨勯煶棰戝寘
            if self.conn_from_mqtt_gateway and len(message) >= 16:
                handled = await self._process_mqtt_audio_message(message)
                if handled:
                    self.mark_active()
                    return

            # 涓嶉渶瑕佸ご閮ㄥ鐞嗘垨娌℃湁澶撮儴鏃讹紝鐩存帴澶勭悊鍘熷娑堟伅
            self.asr_audio_queue.put(message)
            # 鏇存柊鏈€鍚庢敹鍒伴煶棰戝抚鏃堕棿锛堢敤浜庨潤闊冲垽瀹氾級
            try:
                self.last_audio_frame_time = time.time() * 1000
            except Exception:
                pass
            self.mark_active()

    async def _process_mqtt_audio_message(self, message):
        """
        澶勭悊鏉ヨ嚜MQTT缃戝叧鐨勯煶棰戞秷鎭紝瑙ｆ瀽16瀛楄妭澶撮儴骞舵彁鍙栭煶棰戞暟鎹?
        Args:
            message: 鍖呭惈澶撮儴鐨勯煶棰戞秷鎭?
        Returns:
            bool: 鏄惁鎴愬姛澶勭悊浜嗘秷鎭?        """
        try:
            # 鎻愬彇澶撮儴淇℃伅
            timestamp = int.from_bytes(message[8:12], "big")
            audio_length = int.from_bytes(message[12:16], "big")

            # 鎻愬彇闊抽鏁版嵁
            if audio_length > 0 and len(message) >= 16 + audio_length:
                # 鏈夋寚瀹氶暱搴︼紝鎻愬彇绮剧‘鐨勯煶棰戞暟鎹?                audio_data = message[16 : 16 + audio_length]
                # 鍩轰簬鏃堕棿鎴宠繘琛屾帓搴忓鐞?                self._process_websocket_audio(audio_data, timestamp)
                return True
            elif len(message) > 16:
                # 娌℃湁鎸囧畾闀垮害鎴栭暱搴︽棤鏁堬紝鍘绘帀澶撮儴鍚庡鐞嗗墿浣欐暟鎹?                audio_data = message[16:]
                self.asr_audio_queue.put(audio_data)
                return True
        except Exception as e:
            self.logger.bind(tag=TAG).error(f"瑙ｆ瀽WebSocket闊抽鍖呭け璐? {e}")

        # 澶勭悊澶辫触锛岃繑鍥濬alse琛ㄧず闇€瑕佺户缁鐞?        return False

    def _process_websocket_audio(self, audio_data, timestamp):
        """澶勭悊WebSocket鏍煎紡鐨勯煶棰戝寘"""
        # 鍒濆鍖栨椂闂存埑搴忓垪绠＄悊
        if not hasattr(self, "audio_timestamp_buffer"):
            self.audio_timestamp_buffer = {}
            self.last_processed_timestamp = 0
            self.max_timestamp_buffer_size = 20

        # 濡傛灉鏃堕棿鎴虫槸閫掑鐨勶紝鐩存帴澶勭悊
        if timestamp >= self.last_processed_timestamp:
            self.asr_audio_queue.put(audio_data)
            self.last_processed_timestamp = timestamp

            # 澶勭悊缂撳啿鍖轰腑鐨勫悗缁寘
            processed_any = True
            while processed_any:
                processed_any = False
                for ts in sorted(self.audio_timestamp_buffer.keys()):
                    if ts > self.last_processed_timestamp:
                        buffered_audio = self.audio_timestamp_buffer.pop(ts)
                        self.asr_audio_queue.put(buffered_audio)
                        self.last_processed_timestamp = ts
                        processed_any = True
                        break
        else:
            # 涔卞簭鍖咃紝鏆傚瓨
            if len(self.audio_timestamp_buffer) < self.max_timestamp_buffer_size:
                self.audio_timestamp_buffer[timestamp] = audio_data
            else:
                self.asr_audio_queue.put(audio_data)

